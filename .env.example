# ============================================================
# MasterLife V3.0 环境变量模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# ======================== 数据库 (MySQL) ========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pengcheng-system
DB_ROOT_PASSWORD=your_mysql_root_password
DB_USERNAME=pengcheng_app
DB_PASSWORD=your_secure_password_here

# ======================== Redis ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=10

# ======================== PostgreSQL (PGVector) ========================
PG_HOST=localhost
PG_PORT=5432
PG_DB=pengcheng_vector
PG_USERNAME=postgres
PG_PASSWORD=your_pg_password_here

# ======================== AI 服务 ========================
# DashScope (通义千问) — 主模型
DASHSCOPE_API_KEY=sk-your-dashscope-key

# 智谱 GLM — 备用模型（双活）
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_CHAT_MODEL=glm-4-flash

# AI 模型配置
AI_CHAT_MODEL=qwen-plus
AI_EMBEDDING_MODEL=text-embedding-v3

# ======================== SSL (生产环境) ========================
SSL_KEYSTORE_PASSWORD=changeit

# ======================== MinIO (文件存储) ========================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pengcheng

# ======================== 微信 ========================
WECHAT_MINIPROGRAM_APPID=
WECHAT_MINIPROGRAM_SECRET=
WECHAT_MP_APPID=
WECHAT_MP_SECRET=

# ======================== 推送服务 ========================
GETUI_APP_ID=
GETUI_APP_KEY=
GETUI_MASTER_SECRET=

# ======================== OnlyOffice (可选，docx/xlsx/pptx 在线编辑) ========================
ONLYOFFICE_JWT_SECRET=masterlife_onlyoffice_secret
# 仅在使用 OnlyOffice 时配置；Docker 部署时 Document Server 默认 8443
# ONLYOFFICE_SERVER_URL=https://your-domain/onlyoffice/
# kkFileView 在线预览地址（本地 Docker 默认 8012）
# KKFILEVIEW_URL=http://localhost:8012
# 供容器访问宿主机 Spring Boot 的文件 / WOPI 地址（macOS Docker Desktop 推荐使用 host.docker.internal）
# APP_FILE_ACCESS_URL=http://host.docker.internal:8080/api/files
# APP_WOPI_ACCESS_URL=http://host.docker.internal:8080/api

# ======================== Spring Profile ========================
SPRING_PROFILES_ACTIVE=dev
