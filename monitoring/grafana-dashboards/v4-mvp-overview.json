{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "MasterLife V4 MVP 核心看板 — HTTP P95 / OpenAPI QPS / Webhook Delivery / Copilot Actions",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP 请求 P95 响应时间",
      "description": "所有接口的 P95 响应时延（ms）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"MasterLife\"}[5m])) by (le, uri)) * 1000",
          "legendFormat": "P95 {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "OpenAPI 调用 QPS（按 AK）",
      "description": "各 Access Key 的请求速率（req/s）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
          "expr": "sum(rate(pengcheng_openapi_requests_total{application=\"MasterLife\"}[5m])) by (ak)",
          "legendFormat": "AK: {{ak}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Webhook 投递结果",
      "description": "SUCCESS / FAILED / DEAD 各状态的投递速率",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SUCCESS" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "FAILED"  }, "properties": [{ "id": "color", "value": { "fixedColor": "orange","mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DEAD"    }, "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] }
        ]
      },
      "options": {
        "barWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "xField": "Time"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
          "expr": "sum(rate(pengcheng_webhook_delivery_total{application=\"MasterLife\"}[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "AI Copilot 动作次数（累计）",
      "description": "FOLLOW / TODO / APPROVAL 各动作的累计触发次数",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-masterlife" },
          "expr": "sum(pengcheng_ai_copilot_actions_total{application=\"MasterLife\"}) by (action)",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["masterlife", "v4-mvp", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MasterLife V4 MVP Overview",
  "uid": "masterlife-v4-mvp",
  "version": 1
}
