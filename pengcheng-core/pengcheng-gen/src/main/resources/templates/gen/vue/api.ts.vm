#set($dollar = '$')
import { request } from '@/utils/request'

// ${functionName} 类型定义
export interface ${className} {
#foreach($column in $columns)
  ${column.javaField}?: #if($column.javaType == 'Integer' || $column.javaType == 'Long')number#elseif($column.javaType == 'Boolean')boolean#else string#end

#end
}

// ${functionName} API
export const ${classname}Api = {
  // 分页查询
  page(params: { page: number; pageSize: number#foreach($column in $columns)#if($column.isQuery == 1); ${column.javaField}?: #if($column.javaType == 'Integer' || $column.javaType == 'Long')number#elseif($column.javaType == 'Boolean')boolean#else string#end#end#end }) {
    return request({ url: '/${moduleName}/${businessName}/page', method: 'get', params })
  },

  // 获取详情
  detail(${pkColumn.javaField}: #if($pkColumn.javaType == 'Long')number#else string#end) {
    return request({ url: `/${moduleName}/${businessName}/${dollar}{${pkColumn.javaField}}`, method: 'get' })
  },

  // 新增
  create(data: ${className}) {
    return request({ url: '/${moduleName}/${businessName}', method: 'post', data })
  },

  // 修改
  update(data: ${className}) {
    return request({ url: '/${moduleName}/${businessName}', method: 'put', data })
  },

  // 删除
  delete(${pkColumn.javaField}s: #if($pkColumn.javaType == 'Long')number[]#else string[]#end) {
    return request({ url: `/${moduleName}/${businessName}/${dollar}{${pkColumn.javaField}s.join(',')}`, method: 'delete' })
  }
}
