<template>
  <div class="page-container">
    <n-card>
      <!-- 搜索表单 -->
      <div class="search-form">
        <n-form inline :model="searchForm" label-placement="left">
#foreach($column in $columns)
#if($column.isQuery == 1)
#if($column.htmlType == 'input')
          <n-form-item label="${column.columnComment}">
            <n-input v-model:value="searchForm.${column.javaField}" placeholder="请输入${column.columnComment}" clearable />
          </n-form-item>
#elseif($column.htmlType == 'select')
          <n-form-item label="${column.columnComment}">
            <n-select v-model:value="searchForm.${column.javaField}" placeholder="请选择${column.columnComment}" clearable style="width: 150px" :options="[]" />
          </n-form-item>
#elseif($column.htmlType == 'datetime')
          <n-form-item label="${column.columnComment}">
            <n-date-picker v-model:value="searchForm.${column.javaField}" type="datetime" clearable />
          </n-form-item>
#end
#end
#end
          <n-form-item>
            <n-space>
              <n-button type="primary" @click="handleSearch">
                <template #icon><n-icon><SearchOutline /></n-icon></template>
                搜索
              </n-button>
              <n-button @click="handleReset">
                <template #icon><n-icon><RefreshOutline /></n-icon></template>
                重置
              </n-button>
            </n-space>
          </n-form-item>
        </n-form>
      </div>

      <!-- 工具栏 -->
      <div class="table-toolbar">
        <n-space>
          <n-button type="primary" @click="handleAdd">
            <template #icon><n-icon><AddOutline /></n-icon></template>
            新增
          </n-button>
          <n-button type="error" :disabled="selectedIds.length === 0" @click="handleBatchDelete">
            <template #icon><n-icon><TrashOutline /></n-icon></template>
            删除
          </n-button>
        </n-space>
      </div>

      <!-- 表格 -->
      <n-data-table
        :columns="columns"
        :data="tableData"
        :loading="loading"
        :pagination="pagination"
        :row-key="(row) => row.${pkColumn.javaField}"
        @update:page="handlePageChange"
        @update:page-size="handlePageSizeChange"
        @update:checked-row-keys="handleCheck"
      />
    </n-card>

    <!-- 新增/编辑弹窗 -->
    <n-modal v-model:show="modalVisible" preset="card" :title="modalTitle" style="width: 600px">
      <n-form ref="formRef" :model="formData" :rules="formRules" label-placement="left" label-width="100px">
#foreach($column in $columns)
#if($column.isInsert == 1 || $column.isEdit == 1)
#if($column.htmlType == 'input')
        <n-form-item label="${column.columnComment}" path="${column.javaField}">
          <n-input v-model:value="formData.${column.javaField}" placeholder="请输入${column.columnComment}" />
        </n-form-item>
#elseif($column.htmlType == 'textarea')
        <n-form-item label="${column.columnComment}" path="${column.javaField}">
          <n-input v-model:value="formData.${column.javaField}" type="textarea" placeholder="请输入${column.columnComment}" />
        </n-form-item>
#elseif($column.htmlType == 'select')
        <n-form-item label="${column.columnComment}" path="${column.javaField}">
          <n-select v-model:value="formData.${column.javaField}" placeholder="请选择${column.columnComment}" :options="[]" />
        </n-form-item>
#elseif($column.htmlType == 'datetime')
        <n-form-item label="${column.columnComment}" path="${column.javaField}">
          <n-date-picker v-model:value="formData.${column.javaField}" type="datetime" clearable style="width: 100%" />
        </n-form-item>
#elseif($column.htmlType == 'editor')
        <n-form-item label="${column.columnComment}" path="${column.javaField}">
          <RichTextEditor v-model="formData.${column.javaField}" />
        </n-form-item>
#elseif($column.htmlType == 'imageUpload')
        <n-form-item label="${column.columnComment}" path="${column.javaField}">
          <ImageUpload v-model="formData.${column.javaField}" />
        </n-form-item>
#end
#end
#end
      </n-form>
      <template #footer>
        <n-space justify="end">
          <n-button @click="modalVisible = false">取消</n-button>
          <n-button type="primary" @click="handleSubmit">确定</n-button>
        </n-space>
      </template>
    </n-modal>
  </div>
</template>

<script setup lang="ts">
import { ref, reactive, h, onMounted } from 'vue'
import { NButton, NSpace, NIcon, useMessage, useDialog, type DataTableColumns } from 'naive-ui'
import { SearchOutline, RefreshOutline, AddOutline, TrashOutline, CreateOutline } from '@vicons/ionicons5'
import { ${classname}Api, type ${className} } from '@/api/${businessName}'
#foreach($column in $columns)
#if($column.htmlType == 'imageUpload')
import ImageUpload from '@/components/ImageUpload.vue'
#break
#end
#end
#foreach($column in $columns)
#if($column.htmlType == 'editor')
import RichTextEditor from '@/components/RichTextEditor.vue'
#break
#end
#end

const message = useMessage()
const dialog = useDialog()

// 搜索表单
const searchForm = reactive({
#foreach($column in $columns)
#if($column.isQuery == 1)
  ${column.javaField}: #if($column.javaType == 'String')''#else null as number | null#end,
#end
#end
})

// 表格数据
const tableData = ref<${className}[]>([])
const loading = ref(false)
const selectedIds = ref<number[]>([])
const pagination = reactive({
  page: 1,
  pageSize: 10,
  itemCount: 0,
  showSizePicker: true,
  pageSizes: [10, 20, 50]
})

// 弹窗
const modalVisible = ref(false)
const modalTitle = ref('')
const formRef = ref()
const defaultFormData: ${className} = {
#foreach($column in $columns)
#if($column.isInsert == 1 || $column.isEdit == 1)
  ${column.javaField}: #if($column.javaType == 'String')''#elseif($column.javaType == 'Integer' || $column.javaType == 'Long')undefined#else undefined#end,
#end
#end
}
const formData = reactive<${className}>({ ...defaultFormData })

// 表单校验规则
const formRules = {
#foreach($column in $columns)
#if($column.isRequired == 1 && ($column.isInsert == 1 || $column.isEdit == 1))
  ${column.javaField}: { required: true, message: '请输入${column.columnComment}', trigger: 'blur' },
#end
#end
}

// 表格列
const columns: DataTableColumns<${className}> = [
  { type: 'selection' },
#foreach($column in $columns)
#if($column.isList == 1)
#if($column.htmlType == 'imageUpload')
  { 
    title: '${column.columnComment}', 
    key: '${column.javaField}',
    width: 100,
    render(row) {
      return row.${column.javaField} ? h('img', { 
        src: row.${column.javaField}, 
        style: { width: '60px', height: '60px', objectFit: 'cover', borderRadius: '4px' } 
      }) : '-'
    }
  },
#elseif($column.htmlType == 'editor')
  {
    title: '${column.columnComment}',
    key: '${column.javaField}',
    ellipsis: { tooltip: true },
    render(row) {
      const text = row.${column.javaField} ? row.${column.javaField}.replace(/<[^>]+>/g, '') : '-'
      return text.length > 50 ? text.substring(0, 50) + '...' : text
    }
  },
#else
  { title: '${column.columnComment}', key: '${column.javaField}'#if($column.javaField == 'createTime' || $column.javaField == 'updateTime'), width: 180#end },
#end
#end
#end
  {
    title: '操作',
    key: 'actions',
    width: 150,
    render(row) {
      return h(NSpace, null, {
        default: () => [
          h(NButton, { size: 'small', quaternary: true, onClick: () => handleEdit(row) }, {
            default: () => [h(NIcon, null, { default: () => h(CreateOutline) }), ' 编辑']
          }),
          h(NButton, { size: 'small', quaternary: true, type: 'error', onClick: () => handleDelete(row) }, {
            default: () => [h(NIcon, null, { default: () => h(TrashOutline) }), ' 删除']
          })
        ]
      })
    }
  }
]

// 加载数据
async function loadData() {
  loading.value = true
  try {
    const res = await ${classname}Api.page({
      page: pagination.page,
      pageSize: pagination.pageSize,
#foreach($column in $columns)
#if($column.isQuery == 1)
      ${column.javaField}: searchForm.${column.javaField} || undefined,
#end
#end
    })
    tableData.value = res.list
    pagination.itemCount = res.total
  } finally {
    loading.value = false
  }
}

// 搜索
function handleSearch() {
  pagination.page = 1
  loadData()
}

// 重置
function handleReset() {
#foreach($column in $columns)
#if($column.isQuery == 1)
  searchForm.${column.javaField} = #if($column.javaType == 'String')''#else null#end

#end
#end
  handleSearch()
}

// 分页
function handlePageChange(page: number) {
  pagination.page = page
  loadData()
}

function handlePageSizeChange(pageSize: number) {
  pagination.pageSize = pageSize
  pagination.page = 1
  loadData()
}

// 选择
function handleCheck(keys: Array<string | number>) {
  selectedIds.value = keys as number[]
}

// 新增
function handleAdd() {
  modalTitle.value = '新增${functionName}'
  Object.assign(formData, defaultFormData)
  modalVisible.value = true
}

// 编辑
function handleEdit(row: ${className}) {
  modalTitle.value = '编辑${functionName}'
  Object.assign(formData, row)
  modalVisible.value = true
}

// 提交
async function handleSubmit() {
  await formRef.value?.validate()
  try {
    const submitData = { ...formData } as ${className}
#foreach($column in $columns)
#if($column.htmlType == 'imageUpload')
    submitData.${column.javaField} = formData.${column.javaField} ?? ''
#end
#end
    if (submitData.${pkColumn.javaField}) {
      await ${classname}Api.update(submitData)
      message.success('修改成功')
    } else {
      await ${classname}Api.create(submitData)
      message.success('新增成功')
    }
    modalVisible.value = false
    loadData()
  } catch (error) {
    // 错误已在拦截器处理
  }
}

// 删除
function handleDelete(row: ${className}) {
  dialog.warning({
    title: '提示',
    content: '确定要删除该记录吗？',
    positiveText: '确定',
    negativeText: '取消',
    onPositiveClick: async () => {
      try {
        await ${classname}Api.delete([row.${pkColumn.javaField}!])
        message.success('删除成功')
        loadData()
      } catch (error) {
        // 错误已在拦截器处理
      }
    }
  })
}

// 批量删除
function handleBatchDelete() {
  dialog.warning({
    title: '提示',
#set($dollar = '$')
    content: `确定要删除选中的 ${dollar}{selectedIds.value.length} 条记录吗？`,
    positiveText: '确定',
    negativeText: '取消',
    onPositiveClick: async () => {
      try {
        await ${classname}Api.delete(selectedIds.value)
        message.success('删除成功')
        selectedIds.value = []
        loadData()
      } catch (error) {
        // 错误已在拦截器处理
      }
    }
  })
}

onMounted(() => {
  loadData()
})
</script>

<style scoped>
.search-form {
  margin-bottom: 16px;
}

.table-toolbar {
  margin-bottom: 16px;
}
</style>
